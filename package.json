{
  "name": "new-streams",
  "version": "0.2.2",
  "author": "James M Snell <jasnell@gmail.com>",
  "description": "Prototype implementation of a redesigned Web Streams API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/*.test.ts",
    "benchmark": "npx tsx benchmarks/run-all.ts",
    "benchmark:deno": "deno run --allow-read --allow-env --allow-run benchmarks/run-all.ts",
    "benchmark:bun": "bun run benchmarks/run-all.ts",
    "html-samples": "node samples/html/server.mjs",
    "slides": "slidev SLIDES.md"
  },
  "devDependencies": {
    "@slidev/cli": "^52.11.5",
    "@types/node": "^20.11.0",
    "mitata": "^1.0.34",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "streams",
    "async",
    "bytes"
  ],
  "license": "MIT",
  "dependencies": {
    "@slidev/theme-default": "^0.25.0",
    "experimental-fast-webstreams": "^0.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jasnell/new-streams.git"
  }
}
